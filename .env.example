# =====================================================================
# NutriMama + Keen — environment variables
# =====================================================================
# Copy to .env.local for dev. Mirror these into Vercel for prod.
# Anything Keen-related that is missing simply degrades to a safe no-op,
# never crashes.

# ----- Existing NutriMama -----
DATABASE_URL=postgres://...
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GROQ_API_KEY=
GEMINI_API_KEY=
HUGGINGFACE_TOKEN=

# ----- Keen — operator (hidden admin) -----
# Only this email can see /admin and approve proposals.
KEEN_OPERATOR_EMAIL=
# WhatsApp number Keen sends approval requests to (E.164, no whatsapp: prefix).
KEEN_OPERATOR_WHATSAPP=
# Required for L4 approvals (passphrase reply).
KEEN_OPERATOR_PASSPHRASE=

# ----- Keen — cron + Vercel -----
# Vercel cron auth header. Generate: openssl rand -hex 32
CRON_SECRET=

# ----- Keen — working memory + telemetry -----
# Free tier at upstash.com works fine for first 100k users.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Keen — sandboxed MLOps (deferred until first ML job) -----
# Get from https://e2b.dev/dashboard
E2B_API_KEY=
# Template ID printed by: e2b template build --name keen-ml-foundry
E2B_FOUNDRY_TEMPLATE=

# ----- Keen — GitHub PR creation (deferred until first L2+ approval) -----
# Personal access token with `repo` scope.
GITHUB_TOKEN=
# Format: "owner/repo"
GITHUB_REPO=

# ----- Keen — WhatsApp (Twilio) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio sandbox or registered WhatsApp Business sender number.
TWILIO_WHATSAPP_FROM=

# ----- Keen — media pipeline (mock-by-default if missing) -----
YOUTUBE_OAUTH_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# ----- Keen — scholar (optional NCBI quota raise) -----
NCBI_API_KEY=

# ----- Public origin (used by WhatsApp message links) -----
NEXT_PUBLIC_APP_URL=
